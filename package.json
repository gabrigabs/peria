{
  "name": "peria",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run --filter '*' build",
    "lint": "biome check --write",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "dev": "bun run --filter '*' dev",
    "docs:generate": "node packages/cli/bin/peria.js scan && node packages/cli/bin/peria.js github cache write && node packages/cli/bin/peria.js github milestones sync-from-tasks && node packages/cli/bin/peria.js build --renderer fumadocs && node packages/cli/bin/peria.js scan",
    "docs:check": "node packages/cli/bin/peria.js check --json",
    "docs:serve": "node packages/cli/bin/peria.js serve",
    "dogfood:npm": "bun scripts/dogfood-npm.ts",
    "dogfood:preview": "bun scripts/dogfood-preview.ts",
    "dogfood:nest": "bun scripts/dogfood-nest.ts",
    "example:nest": "bun scripts/validate-example-nest.ts",
    "pack:check": "bun scripts/pack-check.ts",
    "release:patch": "bun scripts/version.ts patch",
    "release:minor": "bun scripts/version.ts minor",
    "release:major": "bun scripts/version.ts major",
    "release:dry": "bun scripts/version.ts patch --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@peria/core": "workspace:*",
    "vitest": "^4.1.9"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@peria/renderer": "workspace:*"
  }
}
