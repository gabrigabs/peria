{
  "name": "@peria/adapters",
  "version": "0.1.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    },
    "./fastify": {
      "types": "./dist/fastify.d.ts",
      "import": "./dist/fastify.js"
    },
    "./nest": {
      "types": "./dist/nest.d.ts",
      "import": "./dist/nest.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@nestjs/core": "^10.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "fastify": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrigabs/peria.git",
    "directory": "packages/adapters"
  },
  "publishConfig": {
    "access": "public"
  }
}
