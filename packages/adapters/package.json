{
  "name": "@peria/adapters",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    },
    "./fastify": {
      "types": "./dist/fastify.d.ts",
      "import": "./dist/fastify.js"
    },
    "./nest": {
      "types": "./dist/nest.d.ts",
      "import": "./dist/nest.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js"
    },
    "./elysia": {
      "types": "./dist/elysia.d.ts",
      "import": "./dist/elysia.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@nestjs/core": "^10.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "fastify": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
