{
  "name": "@peria/api-reference",
  "version": "0.1.0",
  "description": "Stoplight Elements integration for Peria API reference",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
