    "@stoplight/elements-core": "^8.5.1",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT"
}
