{
  "name": "@peria/renderer",
  "version": "0.1.1",
  "description": "Fumadocs-compatible documentation renderer for Peria generated wikis",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "echo \"No tests yet\""
  },
  "dependencies": {
    "@peria/core": "0.1.1",
    "marked": "^15.0.0",
    "highlight.js": "^11.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.0",
    "typescript": "^5.7.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrigabs/peria.git",
    "directory": "packages/renderer"
  },
  "publishConfig": {
    "access": "public"
  }
}
