{
  "name": "@peria/renderer",
  "version": "0.1.0",
  "description": "Documentation renderer for Peria with support for static HTML generation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "echo \"No tests yet\""
  },
  "dependencies": {
    "@peria/core": "workspace:*",
    "marked": "^15.0.0",
    "highlight.js": "^11.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.0",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "license": "MIT"
}